/**
 * seats.js
 * Full list of House districts (based on 2020 Census apportionment,
 * in effect 2023–2032) and Senate seats (all 50 states).
 *
 * This is static, well-established data — it doesn't need an API call
 * and won't change until the next reapportionment (2030 Census).
 */

// State -> number of House seats (2020 apportionment, 435 total)
const HOUSE_SEATS_BY_STATE = {
  AL: 7, AK: 1, AZ: 9, AR: 4, CA: 52, CO: 8, CT: 5, DE: 1, FL: 28, GA: 14,
  HI: 2, ID: 2, IL: 17, IN: 9, IA: 4, KS: 4, KY: 6, LA: 6, ME: 2, MD: 8,
  MA: 9, MI: 13, MN: 8, MS: 4, MO: 8, MT: 2, NE: 3, NV: 4, NH: 2, NJ: 12,
  NM: 3, NY: 26, NC: 14, ND: 1, OH: 15, OK: 5, OR: 6, PA: 17, RI: 2, SC: 7,
  SD: 1, TN: 9, TX: 38, UT: 4, VT: 1, VA: 11, WA: 10, WV: 2, WI: 8, WY: 1,
};

const ALL_STATES = Object.keys(HOUSE_SEATS_BY_STATE);

function getAllHouseSeats() {
  const seats = [];
  for (const [state, count] of Object.entries(HOUSE_SEATS_BY_STATE)) {
    if (count === 1) {
      // At-large seat. FEC and Census disagree on the code ("00" vs "01")
      // depending on endpoint, so we track both and try them in order.
      seats.push({ state, district: "1", atLarge: true, fallback: "0" });
    } else {
      for (let d = 1; d <= count; d++) {
        seats.push({ state, district: String(d).padStart(2, "0") });
      }
    }
  }
  return seats; // 435 entries
}

function getAllSenateSeats() {
  // One lookup per state. FEC's election_year filter naturally returns
  // zero candidates for states not on the ballot that cycle — no need
  // to hardcode which Senate class is up.
  return ALL_STATES.map((state) => ({ state, seat: "senate" }));
}

module.exports = { HOUSE_SEATS_BY_STATE, ALL_STATES, getAllHouseSeats, getAllSenateSeats };
